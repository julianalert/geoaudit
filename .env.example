# ── AI Providers ──────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
PERPLEXITY_API_KEY=pplx-...
GOOGLE_AI_API_KEY=...

# ── Supabase ──────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── Stripe ────────────────────────────────────────────────────
# SECURITY: Use TEST keys (sk_test_...) in development.
# Never commit or log live keys (sk_live_...).
# Keep live keys in Vercel encrypted environment variables only.
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── App ───────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Admin ─────────────────────────────────────────────────────
ADMIN_SECRET=change-me-to-a-strong-random-secret

# ── Rate Limiting (optional, recommended for production) ──────
# When set, uses Upstash Redis for distributed rate limiting across
# all serverless instances instead of the in-memory fallback.
# Create a free database at https://upstash.com
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=...
